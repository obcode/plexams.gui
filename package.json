{
	"name": "plexams.gui",
	"version": "0.0.2",
	"author": "Oliver Braun <oliver.braun@hm.edu>",
	"license": "BSD-3-Clause",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"devhost": "vite dev --host",
		"update-schema.graphql": "bash -lc 'set -a && [ -f .env ] && . .env || true; npx --yes get-graphql-schema \"$PLEXAMS_SERVER\" > schema.graphql && npm run codegen'",
		"codegen": "graphql-codegen",
		"build": "vite build",
		"package": "svelte-kit package",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"lint": "prettier --check --plugin-search-dir=. . && eslint .",
		"format": "prettier --write --plugin-search-dir=. ."
	},
	"devDependencies": {
		"@graphql-codegen/cli": "^5.0.7",
		"@graphql-codegen/typescript": "^4.1.6",
		"@graphql-codegen/typescript-operations": "^4.6.1",
		"@svelte-plugins/tooltips": "^3.0.3",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^5.1.0",
		"@tailwindcss/postcss": "^4.3.2",
		"@tailwindcss/typography": "^0.5.20",
		"@vitest/coverage-v8": "^4.1.9",
		"daisyui": "^5.6.10",
		"graphql-request": "^7.4.0",
		"prettier-plugin-svelte": "^3.4.0",
		"svelte": "^5.34.8",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.1.11",
		"theme-change": "^2.5.0",
		"tslib": "^2.8.1",
		"typescript": "^5.8.3",
		"vite": "^6.3.5",
		"vitest": "^4.1.9"
	},
	"type": "module",
	"dependencies": {
		"ansi-to-html": "^0.7.2",
		"graphql-ws": "^6.0.8",
		"html-to-image": "^1.11.13",
		"jszip": "^3.10.1"
	}
}
